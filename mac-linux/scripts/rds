#!/usr/bin/env bash

set -euo pipefail

PROFILE="${1:-}"
SEARCH_TERM="${2:-}"
MAP_FILE="$HOME/.rds-map"

[ -z "$PROFILE" ] && {
  echo "Usage:"
  echo "  dbuat"
  echo "  dbuat aud"
  echo "  dbprod trace"
  exit 1
}

[ ! -f "$MAP_FILE" ] && {
  echo "❌ Mapping file not found (~/.rds-map)"
  exit 1
}

REGION=$(aws configure get region --profile "$PROFILE")
REGION=${REGION:-us-east-1}

aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1 || \
aws sso login --profile "$PROFILE"

# -----------------------------
# Find Jumphost
# -----------------------------
JUMP=$(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters "Name=instance-state-name,Values=running" \
  --query "Reservations[].Instances[?contains(join('', Tags[?Key=='Name'].Value), 'Jumphost')].InstanceId" \
  --output text | head -n 1)

[ -z "$JUMP" ] && {
  echo "❌ No Jumphost found"
  exit 1
}

echo "Using Jumphost: $JUMP"
echo ""

# -----------------------------
# MODE SELECTION (AUTO SAFE)
# -----------------------------
MODE=${MODE:-1}

if [ -t 0 ]; then
  echo ""
  echo "Select Mode:"
  echo "1) Reuse existing tunnels"
  echo "2) Restart tunnels (kill + recreate)"
  echo "3) Exit"
  echo "4) Open new tunnels only"
  read -rp "Enter choice [1/2/3/4]: " MODE
fi

case "$MODE" in
  1)
    echo "🔁 Reusing existing tunnels"
    SKIP_KILL=true
    ;;
  2)
    echo "♻️ Restarting tunnels"
    SKIP_KILL=false
    ;;
  3)
    echo "🚪 Exiting..."
    exit 0
    ;;
  4)
    echo "🚀 Open new tunnels only"
    SKIP_KILL=true
    FORCE_OPEN=true
    ;;
  *)
    echo "❌ Invalid choice"
    exit 1
    ;;
esac

# -----------------------------
# FUNCTIONS
# -----------------------------
is_port_active() {
  nc -z 127.0.0.1 "$1" >/dev/null 2>&1
}

kill_port() {
  lsof -tiTCP:"$1" 2>/dev/null | xargs kill -9 2>/dev/null || true
}

kill_existing_user_sessions() {
  USER_EMAIL=$(aws sts get-caller-identity \
    --profile "$PROFILE" \
    --query "Arn" \
    --output text | awk -F'/' '{print $NF}')

  echo "🔍 Cleaning previous sessions for: $USER_EMAIL"

  aws ssm describe-sessions \
    --state Active \
    --region "$REGION" \
    --profile "$PROFILE" \
    --query "Sessions[?Target=='$JUMP'].[SessionId,Owner]" \
    --output text | while read SESSION_ID OWNER
  do
    if [[ "$OWNER" == *"$USER_EMAIL"* ]]; then
      echo "❌ Killing: $SESSION_ID"
      aws ssm terminate-session \
        --session-id "$SESSION_ID" \
        --region "$REGION" \
        --profile "$PROFILE"
    fi
  done
}

start_tunnel() {
  local DB=$1
  local PORT=$2
  local ENDPOINT=$3

  if is_port_active "$PORT"; then
    echo "✅ $DB already running on port $PORT"
    return
  fi

  echo "🚀 Starting: $DB → localhost:$PORT"

  kill_port "$PORT"

  nohup aws ssm start-session \
    --target "$JUMP" \
    --profile "$PROFILE" \
    --region "$REGION" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$ENDPOINT\"],\"portNumber\":[\"3306\"],\"localPortNumber\":[\"$PORT\"]}" \
    > /tmp/ssm-$PORT.log 2>&1 < /dev/null &

  disown

  echo "⏳ Tunnel started: $DB ($PORT)"
}


# -----------------------------
# CLEANUP
# -----------------------------
if [ "$SKIP_KILL" = false ]; then
  kill_existing_user_sessions
fi

# -----------------------------
# READ DB MAP
# -----------------------------
CURRENT_ENV=""
MATCHED_DBS=()
MATCHED_PORTS=()

while IFS="=" read -r DB PORT || [ -n "$DB" ]; do
  DB=$(echo "$DB" | tr -d '\r' | xargs)
  PORT=$(echo "$PORT" | tr -d '\r' | xargs)

  [[ -z "$DB" ]] && continue

  case "$DB" in
    "[uat_databases]") CURRENT_ENV="uat"; continue ;;
    "[prod_databases]") CURRENT_ENV="prod"; continue ;;
  esac

  [[ "$DB" =~ ^# ]] && continue
  [[ "$CURRENT_ENV" != "$PROFILE" ]] && continue

  if [[ -n "$SEARCH_TERM" ]]; then
    echo "$DB" | grep -qi "$SEARCH_TERM" || continue
  fi

  MATCHED_DBS+=("$DB")
  MATCHED_PORTS+=("$PORT")

done < "$MAP_FILE"

[ ${#MATCHED_DBS[@]} -eq 0 ] && {
  echo "❌ No matching databases found"
  exit 1
}

# -----------------------------
# SHOW DB LIST
# -----------------------------
printf "%-5s %-35s %-10s\n" "No" "Database Name" "Port"
printf "%-5s %-35s %-10s\n" "-----" "-----------------------------------" "----------"

for i in "${!MATCHED_DBS[@]}"; do
  printf "%-5s %-35s %-10s\n" "$((i+1))" "${MATCHED_DBS[$i]}" "${MATCHED_PORTS[$i]}"
done

echo ""

# -----------------------------
# MULTI SELECT
# -----------------------------
read -rp "Enter DB numbers (e.g. 1 2 3): " choice

SELECTED_INDEXES=()

for num in $choice; do
  index=$((num-1))

  if [[ $index -lt 0 || $index -ge ${#MATCHED_DBS[@]} ]]; then
    echo "❌ Invalid selection: $num"
    exit 1
  fi

  SELECTED_INDEXES+=("$index")
done

# Remove duplicates
SELECTED_INDEXES=($(printf "%s\n" "${SELECTED_INDEXES[@]}" | sort -u))

# Limit tunnels
MAX_TUNNELS=3
if [ "${#SELECTED_INDEXES[@]}" -gt "$MAX_TUNNELS" ]; then
  echo "⚠️ Max $MAX_TUNNELS tunnels allowed"
  exit 1
fi

# -----------------------------
# START TUNNELS
# -----------------------------
for idx in "${SELECTED_INDEXES[@]}"; do
  DB="${MATCHED_DBS[$idx]}"
  PORT="${MATCHED_PORTS[$idx]}"

  ENDPOINT=$(aws rds describe-db-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --db-instance-identifier "$DB" \
    --query "DBInstances[0].Endpoint.Address" \
    --output text)

  start_tunnel "$DB" "$PORT" "$ENDPOINT"
done

echo ""
echo "--------------------------------------------"
echo "✅ Tunnel setup completed"
echo "Host: 127.0.0.1"
echo "--------------------------------------------"