#!/usr/bin/env bash

set -euo pipefail

PROFILE="${1:-}"
SEARCH_TERM="${2:-}"
MAP_FILE="$HOME/.rds-map"

[ -z "$PROFILE" ] && {
  echo "Usage:"
  echo "  dbuat"
  echo "  dbprod"
  exit 1
}

[ ! -f "$MAP_FILE" ] && {
  echo "❌ Mapping file not found (~/.rds-map)"
  exit 1
}

REGION=$(aws configure get region --profile "$PROFILE")
REGION=${REGION:-us-east-1}

# Keep original fast behavior
aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1 || \
aws sso login --profile "$PROFILE"

# ---------------------------------
# FIND JUMPHOST (FAST RANDOM)
# ---------------------------------
echo "Fetching connection..."

JUMPS=($(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters "Name=instance-state-name,Values=running" \
  --query "Reservations[].Instances[?contains(join('', Tags[?Key=='Name'].Value), 'Jumphost')].InstanceId" \
  --output text))

[ ${#JUMPS[@]} -eq 0 ] && {
  echo "❌ No gateway hosts available"
  exit 1
}

JUMP="${JUMPS[$RANDOM % ${#JUMPS[@]}]}"

echo "Connected via secure gateway ($JUMP)"

# -----------------------------
# FUNCTIONS
# -----------------------------
kill_port() {
  lsof -tiTCP:"$1" 2>/dev/null | xargs kill -9 2>/dev/null || true
}



kill_user_sessions() {
  USER=$(aws sts get-caller-identity \
    --profile "$PROFILE" \
    --query "Arn" \
    --output text | awk -F'/' '{print $NF}')

  echo ""
  echo "Your active database connections:"
  echo ""

  MATCH_FOUND=false

  aws ssm describe-sessions \
    --state Active \
    --region "$REGION" \
    --profile "$PROFILE" \
    --query "Sessions[*].[SessionId,Owner,DocumentName,Target,StartDate]" \
    --output text | while read SESSION_ID OWNER DOC TARGET START
  do
    if [[ "$OWNER" == *"$USER"* ]] && \
       [[ "$DOC" == "AWS-StartPortForwardingSessionToRemoteHost" ]]; then

      printf "%-40s %-20s %-15s\n" "$SESSION_ID" "$TARGET" "$START"
      MATCH_FOUND=true
    fi
  done

  echo ""

  echo "Cleaning your database connections..."

  aws ssm describe-sessions \
    --state Active \
    --region "$REGION" \
    --profile "$PROFILE" \
    --query "Sessions[*].[SessionId,Owner,DocumentName]" \
    --output text | while read SESSION_ID OWNER DOC
  do
    if [[ "$OWNER" == *"$USER"* ]] && \
       [[ "$DOC" == "AWS-StartPortForwardingSessionToRemoteHost" ]]; then

      echo "Closing: $SESSION_ID"

      aws ssm terminate-session \
        --session-id "$SESSION_ID" \
        --region "$REGION" \
        --profile "$PROFILE" >/dev/null 2>&1
    fi
  done

  echo ""
  echo "✅ Your database connections cleared"
}


start_connection() {
  local DB=$1
  local PORT=$2
  local ENDPOINT=$3

  echo "Connecting: $DB (127.0.0.1:$PORT)"

  kill_port "$PORT"

  nohup aws ssm start-session \
    --target "$JUMP" \
    --profile "$PROFILE" \
    --region "$REGION" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$ENDPOINT\"],\"portNumber\":[\"3306\"],\"localPortNumber\":[\"$PORT\"]}" \
    > /tmp/ssm-$PORT.log 2>&1 < /dev/null &

  disown
}

# -----------------------------
# READ DB MAP
# -----------------------------
CURRENT_ENV=""
MATCHED_DBS=()
MATCHED_PORTS=()

while IFS="=" read -r DB PORT || [ -n "$DB" ]; do
  DB=$(echo "$DB" | tr -d '\r' | xargs)
  PORT=$(echo "$PORT" | tr -d '\r' | xargs)

  [[ -z "$DB" ]] && continue

  case "$DB" in
    "[uat_databases]") CURRENT_ENV="uat"; continue ;;
    "[prod_databases]") CURRENT_ENV="prod"; continue ;;
  esac

  [[ "$DB" =~ ^# ]] && continue
  [[ "$CURRENT_ENV" != "$PROFILE" ]] && continue

  if [[ -n "$SEARCH_TERM" ]]; then
    echo "$DB" | grep -qi "$SEARCH_TERM" || continue
  fi

  MATCHED_DBS+=("$DB")
  MATCHED_PORTS+=("$PORT")

done < "$MAP_FILE"

[ ${#MATCHED_DBS[@]} -eq 0 ] && {
  echo "❌ No databases found"
  exit 1
}

# -----------------------------
# SHOW DB LIST
# -----------------------------
echo ""
echo "Available Databases:"
echo ""

for i in "${!MATCHED_DBS[@]}"; do
  printf "%-3s %-20s (Port: %s)\n" "$((i+1))" "${MATCHED_DBS[$i]}" "${MATCHED_PORTS[$i]}"
done

echo ""
echo "Enter database number to connect (e.g. 1 or 1,2,3)"
echo "Press Enter → connect ALL"
echo "Type 'c' → clean old connections"
echo "Type 'q' → exit"
echo ""

# -----------------------------
# USER INPUT (SINGLE INPUT UX)
# -----------------------------
read -rp "Selection: " choice

if [[ -z "$choice" ]]; then
  # ALL
  SELECTED_INDEXES=($(seq 0 $((${#MATCHED_DBS[@]} - 1))))

elif [[ "$choice" == "c" ]]; then
  kill_user_sessions
  exit 0

elif [[ "$choice" == "q" ]]; then
  exit 0

else
  choice=$(echo "$choice" | tr ',' ' ' | xargs)

  SELECTED_INDEXES=()

  for num in $choice; do
    index=$((num-1))

    if [[ $index -lt 0 || $index -ge ${#MATCHED_DBS[@]} ]]; then
      echo "❌ Invalid selection: $num"
      exit 1
    fi

    SELECTED_INDEXES+=("$index")
  done

  SELECTED_INDEXES=($(printf "%s\n" "${SELECTED_INDEXES[@]}" | sort -u))

  # limit only for manual selection
  MAX=3
  if [ "${#SELECTED_INDEXES[@]}" -gt "$MAX" ]; then
    echo "⚠️ Max $MAX connections allowed"
    exit 1
  fi
fi

# -----------------------------
# START CONNECTIONS
# -----------------------------
for idx in "${SELECTED_INDEXES[@]}"; do
  DB="${MATCHED_DBS[$idx]}"
  PORT="${MATCHED_PORTS[$idx]}"

  ENDPOINT=$(aws rds describe-db-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --db-instance-identifier "$DB" \
    --query "DBInstances[0].Endpoint.Address" \
    --output text)

  start_connection "$DB" "$PORT" "$ENDPOINT"
done

echo ""
echo "--------------------------------------------"
echo "✅ Connection ready"
echo "Use: 127.0.0.1:<port>"
echo "--------------------------------------------"