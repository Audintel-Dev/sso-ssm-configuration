#!/usr/bin/env bash

set -euo pipefail

PROFILE="${1:-}"
SEARCH_TERM="${2:-}"
MAP_FILE="$HOME/.rds-map"

[ -z "$PROFILE" ] && {
  echo "Usage:"
  echo "  dbuat"
  echo "  dbuat aud"
  echo "  dbprod trace"
  exit 1
}

[ ! -f "$MAP_FILE" ] && {
  echo "❌ Mapping file not found (~/.rds-map)"
  exit 1
}

REGION=$(aws configure get region --profile "$PROFILE")
REGION=${REGION:-us-east-1}

aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1 || \
aws sso login --profile "$PROFILE"

# -----------------------------
# Find Jumphost
# -----------------------------
JUMP=$(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters "Name=instance-state-name,Values=running" \
  --query "Reservations[].Instances[?contains(join('', Tags[?Key=='Name'].Value), 'Jumphost')].InstanceId" \
  --output text | head -n 1)

[ -z "$JUMP" ] && {
  echo "❌ No Jumphost found"
  exit 1
}

echo "Using Jumphost: $JUMP"
echo ""

# -----------------------------
# FUNCTIONS
# -----------------------------
is_port_active() {
  nc -z 127.0.0.1 "$1" >/dev/null 2>&1
}

kill_port() {
  lsof -tiTCP:"$1" 2>/dev/null | xargs kill -9 2>/dev/null || true
}

start_tunnel() {
  local DB=$1
  local PORT=$2
  local ENDPOINT=$3

  if is_port_active "$PORT"; then
    echo "✅ $DB already active on port $PORT"
    return
  fi

  echo "🚀 Starting: $DB → localhost:$PORT"

  kill_port "$PORT"

  aws ssm start-session \
    --target "$JUMP" \
    --profile "$PROFILE" \
    --region "$REGION" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$ENDPOINT\"],\"portNumber\":[\"3306\"],\"localPortNumber\":[\"$PORT\"]}" \
    > /tmp/ssm-$PORT.log 2>&1 &

  echo "⏳ Tunnel launching: $DB ($PORT)"
}

# -----------------------------
# Read matching DBs
# -----------------------------
CURRENT_ENV=""
MATCHED_DBS=()
MATCHED_PORTS=()

while IFS="=" read -r DB PORT || [ -n "$DB" ]; do

  DB=$(echo "$DB" | tr -d '\r' | xargs)
  PORT=$(echo "$PORT" | tr -d '\r' | xargs)

  [[ -z "$DB" ]] && continue

  case "$DB" in
    "[uat_databases]")
      CURRENT_ENV="uat"
      continue
      ;;
    "[prod_databases]")
      CURRENT_ENV="prod"
      continue
      ;;
  esac

  [[ "$DB" =~ ^# ]] && continue
  [[ "$CURRENT_ENV" != "$PROFILE" ]] && continue

  if [[ -n "$SEARCH_TERM" ]]; then
    if ! echo "$DB" | grep -qi "$SEARCH_TERM"; then
      continue
    fi
  fi

  MATCHED_DBS+=("$DB")
  MATCHED_PORTS+=("$PORT")

done < "$MAP_FILE"

# No matches
if [ ${#MATCHED_DBS[@]} -eq 0 ]; then
  echo "❌ No matching databases found"
  exit 1
fi

# -----------------------------
# Show Table
# -----------------------------
printf "%-5s %-35s %-10s\n" "No" "Database Name" "Port"
printf "%-5s %-35s %-10s\n" "-----" "-----------------------------------" "----------"

for i in "${!MATCHED_DBS[@]}"; do
  printf "%-5s %-35s %-10s\n" \
    "$((i+1))" \
    "${MATCHED_DBS[$i]}" \
    "${MATCHED_PORTS[$i]}"
done

echo ""

# -----------------------------
# User Selection
# -----------------------------
read -rp "Enter DB number to connect (or type 'all'): " choice

if [[ "$choice" == "all" ]]; then
  SELECTED_INDEXES=("${!MATCHED_DBS[@]}")
else
  index=$((choice-1))

  if [[ $index -lt 0 || $index -ge ${#MATCHED_DBS[@]} ]]; then
    echo "❌ Invalid selection"
    exit 1
  fi

  SELECTED_INDEXES=("$index")
fi

# -----------------------------
# Start selected tunnels
# -----------------------------
for idx in "${SELECTED_INDEXES[@]}"; do
  DB="${MATCHED_DBS[$idx]}"
  PORT="${MATCHED_PORTS[$idx]}"

  ENDPOINT=$(aws rds describe-db-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --db-instance-identifier "$DB" \
    --query "DBInstances[0].Endpoint.Address" \
    --output text)

  start_tunnel "$DB" "$PORT" "$ENDPOINT"
done

echo ""
echo "--------------------------------------------"
echo "✅ Tunnel setup completed"
echo "Host: 127.0.0.1"
echo "Verify: nc -zv localhost <port>"
echo "--------------------------------------------"


