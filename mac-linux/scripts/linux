#!/usr/bin/env bash

set -euo pipefail

# Ensure bash
if [ -z "${BASH_VERSION:-}" ]; then
  echo "Please run with bash"
  exit 1
fi

PROFILE="${1:?Usage: instances <uat|prod>}"

# ── Region ────────────────────────────────────────────────
REGION=$(aws configure get region --profile "$PROFILE" 2>/dev/null || echo "us-east-1")

# ── SSO login ─────────────────────────────────────────────
aws sts get-caller-identity --profile "$PROFILE" &>/dev/null \
  || aws sso login --profile "$PROFILE"

# ── Fetch instances (Linux only) ──────────────────────────
instances=$(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters \
    "Name=instance-state-name,Values=running" \
    "Name=platform-details,Values=Linux/UNIX" \
  --query "Reservations[].Instances[].{
  Name:Tags[?Key=='Name']|[0].Value,
  Id:InstanceId,
  ImageId:ImageId,
  LaunchTime:LaunchTime
  }" \
  --output json)

[[ "$instances" == "[]" ]] && { echo "No running Linux instances found"; exit 1; }

# ── Display instances ─────────────────────────────────────
printf "%-4s %-40s %-22s %-25s\n" "No" "Instance Name" "Instance ID" "Creation Time"

i=1
instance_ids=()
instance_image_ids=()

while IFS= read -r row; do
  name=$(jq -r '.Name // "No-Name"' <<< "$row")
  id=$(jq -r '.Id' <<< "$row")
  image=$(jq -r '.ImageId' <<< "$row")
  launch_time=$(jq -r '.LaunchTime' <<< "$row")

  printf "%-4s %-40s %-22s %-25s\n" "$i" "$name" "$id" "$launch_time"

  instance_ids+=("$id")
  instance_image_ids+=("$image")

  ((i++))
done <<< "$(echo "$instances" | jq -c '.[]')"

# ── Select instance ───────────────────────────────────────
echo ""
read -rp "Select instance number: " choice

# Validate input
if [[ -z "$choice" || ! "$choice" =~ ^[0-9]+$ || "$choice" -lt 1 || "$choice" -gt "${#instance_ids[@]}" ]]; then
  echo "Invalid selection"
  exit 1
fi

INSTANCE_ID="${instance_ids[$((choice-1))]}"
IMAGE_ID="${instance_image_ids[$((choice-1))]}"

INSTANCE_NAME=$(jq -r --arg id "$INSTANCE_ID" '.[] | select(.Id == $id) | .Name // "unknown"' <<< "$instances")

# ── Detect OS via SSM ─────────────────────────────────────
COMMAND_ID=$(aws ssm send-command \
  --instance-ids "$INSTANCE_ID" \
  --document-name "AWS-RunShellScript" \
  --parameters 'commands=["cat /etc/os-release"]' \
  --profile "$PROFILE" \
  --region "$REGION" \
  --query "Command.CommandId" \
  --output text)

sleep 3

OS_INFO=$(aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$INSTANCE_ID" \
  --profile "$PROFILE" \
  --region "$REGION" \
  --query "StandardOutputContent" \
  --output text)

# ── Determine login user ──────────────────────────────────
if echo "$OS_INFO" | grep -qi "ubuntu"; then
  TARGET_USER="ubuntu"
elif echo "$OS_INFO" | grep -Eqi "amazon linux|amzn"; then
  TARGET_USER="ec2-user"
else
  TARGET_USER="ec2-user"
fi

echo "Using login user: $TARGET_USER"

# ── Build CLEAN PS1 (no color, no emoji) ──────────────────
RC_CONTENT="# SSM_PROMPT_INJECTED
unset PROMPT_COMMAND
unset color_prompt
unset force_color_prompt

# Disable terminal control sequences
bind 'set enable-bracketed-paste off' 2>/dev/null || true
export TERM=dumb

export PS1=\"[${PROFILE}][${INSTANCE_NAME}] [\\u@\\h \\W]\\\\$ \""

B64=$(printf '%s' "$RC_CONTENT" | base64 | tr -d '\n')

# ── Prompt injection script ───────────────────────────────
FIX_SCRIPT='#!/bin/bash

# Skip if already configured
if grep -q "SSM_PROMPT_INJECTED" /etc/profile.d/ssm_prompt.sh 2>/dev/null; then
  exit 0
fi

# Disable default ubuntu prompt coloring
sed -i "s/^force_color_prompt=yes/force_color_prompt=no/" /home/ubuntu/.bashrc 2>/dev/null || true
sed -i "s/^force_color_prompt=yes/force_color_prompt=no/" /root/.bashrc 2>/dev/null || true

# Write prompt
echo PLACEHOLDER_B64 | base64 -d > /etc/profile.d/ssm_prompt.sh
chmod +x /etc/profile.d/ssm_prompt.sh

# Ensure it loads
for f in /home/ubuntu/.bashrc /root/.bashrc; do
  if [ -f "$f" ]; then
    grep -q "SSM_PROMPT_INJECTED" "$f" || {
      echo "" >> "$f"
      echo "# SSM_PROMPT_INJECTED" >> "$f"
      echo "source /etc/profile.d/ssm_prompt.sh" >> "$f"
    }
  fi
done
'

FIX_SCRIPT="${FIX_SCRIPT//PLACEHOLDER_B64/$B64}"
FIX_B64=$(printf '%s' "$FIX_SCRIPT" | base64 | tr -d '\n')

# ── Inject prompt ─────────────────────────────────────────
echo "Configuring prompt (background)..."

aws ssm send-command \
  --instance-ids "$INSTANCE_ID" \
  --document-name "AWS-RunShellScript" \
  --parameters "commands=[\"echo $FIX_B64 | base64 -d | bash\"]" \
  --profile "$PROFILE" \
  --region "$REGION" \
  > /dev/null

  
# ── Connect ───────────────────────────────────────────────
echo "Connecting as $TARGET_USER..."

aws ssm start-session \
  --target "$INSTANCE_ID" \
  --profile "$PROFILE" \
  --region "$REGION" \
  --document-name AWS-StartInteractiveCommand \
  --parameters "command=[\"sudo -u ${TARGET_USER} -i\"]"